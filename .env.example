# Required
DB_USER=user
DB_PASSWORD=請向隊友索取
DB_NAME=vexa

VEXA_ADMIN_API_KEY=請向隊友索取
TRANSCRIPTION_SERVICE_URL=https://transcription.vexa.ai/v1/audio/transcriptions
TRANSCRIPTION_SERVICE_TOKEN=請向隊友索取

JWT_SECRET=請向隊友索取

SMTP_HOST=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# Optional (defaults to VEXA_API_URL when unset)
# VEXA_ADMIN_API_URL=http://localhost:8056

# Optional: app URL and auth/session
# NEXT_PUBLIC_APP_URL=http://localhost:3001
# NEXTAUTH_URL=http://localhost:3001
# NEXTAUTH_SECRET=change-me
# JWT_SECRET=change-me

# Optional: transcript sharing and docs URLs
# NEXT_PUBLIC_TRANSCRIPT_SHARE_BASE_URL=https://share.example.com
# NEXT_PUBLIC_VEXA_WS_URL=ws://localhost:8056/ws
# NEXT_PUBLIC_BASE_URL=https://dashboard.example.com
# NEXT_PUBLIC_WEBAPP_URL=https://webapp.vexa.ai

# Optional: default bot config
# DEFAULT_BOT_NAME=Vexa - Open Source Bot

# Optional: AI assistant
# AI_MODEL=openai/gpt-4o
# AI_API_KEY=
# AI_BASE_URL=

# Optional: email authentication (magic link)
# SMTP_HOST=
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Optional: Google OAuth
# ENABLE_GOOGLE_AUTH=false
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# Optional: Zoom OAuth
# ZOOM_OAUTH_CLIENT_ID=
# ZOOM_OAUTH_CLIENT_SECRET=
# ZOOM_OAUTH_REDIRECT_URI=
# ZOOM_OAUTH_STATE_SECRET=

# Optional: registration policy
# ALLOW_REGISTRATIONS=true
# ALLOWED_EMAIL_DOMAINS=
